# Pinterest Bot Configuration
# Copy this file to .env and fill in your actual values

# --- Authentication ---
PINTEREST_EMAIL=your_email@example.com
PINTEREST_PASSWORD=your_secure_password

# --- Targeting ---
# Comma-separated list of keywords to search for, or specific board/profile URLs
TARGET_KEYWORDS=pinterest, home decor, diy crafts
TARGET_PROFILES=

# --- Actions ---
# Set to true/false to enable/disable specific actions
ACTION_FOLLOW=true
ACTION_LIKE=true
ACTION_SAVE=true # Repin
ACTION_COMMENT=false

# Sample comments (one will be chosen randomly if ACTION_COMMENT is true)
COMMENTS=Love this! 😍,Great idea, saving this for later.,Absolutely stunning!

# --- Timing & Safety (in milliseconds) ---
# Random delay ranges to simulate human behavior
MIN_DELAY_BETWEEN_ACTIONS=3000
MAX_DELAY_BETWEEN_ACTIONS=8000
MIN_DELAY_BETWEEN_PAGES=10000
MAX_DELAY_BETWEEN_PAGES=20000

# Maximum actions per session to prevent bans
MAX_FOLLOWS_PER_SESSION=15
MAX_LIKES_PER_SESSION=30
MAX_SAVES_PER_SESSION=20

# --- Browser ---
# Set to true to see the browser window (useful for debugging)
HEADLESS=false
